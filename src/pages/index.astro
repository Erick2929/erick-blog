---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

function readingTime(body: string): number {
  const words = body.trim().split(/\s+/).length;
  return Math.max(1, Math.round(words / 250));
}
---

<Base title="erick.dev" description="Notes and learnings from a dev.">
  <ul class="post-list">
    {posts.map(post => (
      <li>
        <a href={`/${post.id}/`} class="post-link">
          <div class="post-title">{post.data.title}</div>
          <div class="post-meta">
            {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
            &middot; {readingTime(post.body ?? '')} min
          </div>
          {post.data.description && (
            <div class="post-desc">{post.data.description}</div>
          )}
        </a>
        {post.data.tags && post.data.tags.length > 0 && (
          <div class="tags">
            {post.data.tags.map(tag => <span class="tag">{tag}</span>)}
          </div>
        )}
      </li>
    ))}
  </ul>

  {posts.length === 0 && (
    <p style="color: var(--fg-muted); padding: 3rem 0;">
      No posts yet.
    </p>
  )}
</Base>

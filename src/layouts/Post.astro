---
import Base from './Base.astro';

interface Props {
  title: string;
  date: Date;
  description?: string;
  tags?: string[];
  readingTime: number;
}

const { title, date, description, tags, readingTime } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<Base title={title} description={description}>
  <div class="post-header">
    <h1>{title}</h1>
    <div class="post-meta">
      {formattedDate} &middot; {readingTime} min read
    </div>
    {tags && tags.length > 0 && (
      <div class="tags">
        {tags.map(tag => <span class="tag">{tag}</span>)}
      </div>
    )}
  </div>

  <article class="prose">
    <slot />
  </article>

  <a href="/" class="back-link">← all posts</a>
</Base>
